node_modules/

# build output
dist/
out/
build/

# e2e (Playwright) artifacts
test-results/
playwright-report/
.playwright/

# NEVER commit IPACS-derived scanned data (real object names + real dimensions).
# The catalog is regenerated by `npm run scan` into the app's userData at runtime;
# it must not live in the repo or any artifact (see docs/PCT_DESIGN §M3 CI check).
catalog.json
*.catalog.json
/scan-out/

# logs / editor / os
*.log
.vscode/
.idea/
.DS_Store
Thumbs.db

# Local probe / test projects (Juan's own, used for the in-sim gate). Kept on disk, not committed;
# root-anchored so a future curated examples/suiza.json is unaffected.
/italia.json
/suiza*.json

# local-only — internal design/review docs and local editor/preview config.
# Kept on disk (shared with Claude locally); never pushed to GitHub.
docs/
.claude/

# Local reference material — never published. Kept on disk, root-anchored
# so nothing here is ever `git add`-ed.
/_local_reference/
